#!/usr/bin/env bash
set -euo pipefail

# Format all Nix files before commit
nix --extra-experimental-features 'nix-command flakes' fmt . 2>/dev/null

# Fail if formatter changed anything (re-stage and recommit)
if ! git diff --quiet; then
  echo ""
  echo "  nix fmt made changes — review, re-stage, and recommit:"
  git diff --stat | sed 's/^/  /'
  echo ""
  exit 1
fi

{
  // UI & View
  "theme": {
    "mode": "dark",
    "light": "GitHub Light",
    "dark": "Rosé Pine Moon"
  },
  "icon_theme": "Warm Charmed Icons",
  "diff_view_style": "split",
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": true,
    "auto_reveal_entries": false
  },
  "git_panel": {
    "dock": "left",
    "sort_by_path": true,
    "tree_view": true
  },

  // Editor
  "base_keymap": "VSCode",
  "relative_line_numbers": "disabled",
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 15,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 14.0,
  "buffer_line_height": "comfortable",
  "soft_wrap": "editor_width",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },

  // Git
  "git": {
    "inline_blame": {
      "enabled": true
    }
  },

  // Editor predictions
  "edit_predictions": {
    "provider": "copilot"
  },

  // Workspace & Files
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/.next",
    "**/dist",
    "**/out",
    "**/build"
  ],

  // Languages & LSP
  "inlay_hints": {
    "enabled": true
  },
  "languages": {
    "TypeScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "language_servers": ["emmet-language-server", "..."],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JavaScript": {
      "language_servers": ["emmet-language-server", "..."],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JSON": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "JSONC": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "CSS": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "Nix": {
      "formatter": {
        "external": {
          "command": "alejandra"
        }
      }
    }
  },
  "lsp": {
    "tailwindcss-language-server": {
      "initialization_options": {
        "userLanguages": {
          "rust": "html"
        }
      },
      "settings": {
        "tailwindCSS": {
          "experimental": {
            "classRegex": [
              ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["twMerge\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["tv\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
            ]
          }
        }
      }
    }
  },

  // Terminal
  "terminal": {
    "font_family": "JetBrainsMonoNL Nerd Font Mono",
    "font_size": 12.0,
    "cursor_shape": "bar",
    "env": {
      "EDITOR": "zed --wait"
    },
    "toolbar": {
      "breadcrumbs": false
    }
  },

  // Extension/Agent
  "agent": {
    "enabled": true,
    "dock": "right",
    "button": true
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  }
}

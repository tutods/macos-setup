{
  // ─── Window ──────────────────────────────────────────────────────────────
  "use_system_window_tabs": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // ─── Theme & Appearance ──────────────────────────────────────────────────
  "theme": {
    "mode": "dark",
    "light": "GitHub Light",
    "dark": "Rosé Pine Moon"
  },
  "icon_theme": "Warm Charmed Icons",
  "diff_view_style": "split",

  // ─── Panels ──────────────────────────────────────────────────────────────
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": true,
    "auto_reveal_entries": false,
    "indent_size": 16
  },
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left",
    "sort_by_path": true,
    "tree_view": true
  },

  // ─── Tabs ────────────────────────────────────────────────────────────────
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": true
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },

  // ─── Editor ──────────────────────────────────────────────────────────────
  "base_keymap": "VSCode",
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 15,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 14.0,
  "buffer_font_features": { "calt": true },
  "buffer_line_height": "comfortable",
  "tab_size": 2,
  "relative_line_numbers": "disabled",
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "unnecessary_code_fade": 0.5,
  "restore_on_startup": "last_session",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "extend_comment_on_newline": true,
  "wrap_guides": [80, 120],
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "use_smartcase_search": true,
  "use_autoclose": true,
  "use_auto_surround": true,
  "linked_edits": true,
  "seed_search_query_from_cursor": "selection",
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },

  // ─── Gutter ──────────────────────────────────────────────────────────────
  "gutter": {
    "line_numbers": true,
    "code_actions": true,
    "runnables": true,
    "breakpoints": true,
    "folds": true
  },

  // ─── Scrollbar ───────────────────────────────────────────────────────────
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
    "diagnostics": "all"
  },

  // ─── Completions & Intelligence ──────────────────────────────────────────
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "auto_signature_help": true,
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },

  // ─── Edit Predictions (Copilot) ──────────────────────────────────────────
  "edit_predictions": {
    "provider": "copilot",
    "allow_data_collection": "no",
    "copilot": {
      "enable_next_edit_suggestions": true
    }
  },

  // ─── Git ─────────────────────────────────────────────────────────────────
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600
    }
  },

  // ─── Diagnostics ─────────────────────────────────────────────────────────
  "diagnostics": {
    "include_warnings": true
  },

  // ─── Workspace & Files ───────────────────────────────────────────────────
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/.next",
    "**/dist",
    "**/out",
    "**/build",
    "**/.turbo",
    "**/.vercel",
    "**/.cache",
    "**/.parcel-cache",
    "**/coverage",
    "**/.nyc_output",
    "**/storybook-static"
  ],
  "file_nesting": {
    "enabled": true,
    "patterns": {
      "*.ts": ["$(capture).js", "$(capture).d.ts", "$(capture).test.ts", "$(capture).spec.ts"],
      "*.tsx": ["$(capture).test.tsx", "$(capture).spec.tsx", "$(capture).stories.tsx", "$(capture).stories.ts"],
      "package.json": ["package-lock.json", "pnpm-lock.yaml", "yarn.lock", ".npmrc", ".nvmrc", ".node-version"],
      "tsconfig.json": ["tsconfig.*.json"],
      ".env": [".env.*", ".env.local", ".env.*.local"],
      "next.config.*": ["next-env.d.ts"],
      "vite.config.*": ["vitest.config.*"],
      "tailwind.config.*": ["postcss.config.*"]
    }
  },

  // ─── Languages ───────────────────────────────────────────────────────────
  "languages": {
    "TypeScript": {
      "language_servers": ["!typescript-language-server", "..."],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "language_servers": ["emmet-language-server", "!typescript-language-server", "..."],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JavaScript": {
      "language_servers": ["emmet-language-server", "!typescript-language-server", "..."],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JSX": {
      "language_servers": ["emmet-language-server", "!typescript-language-server", "..."],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "HTML": {
      "language_servers": ["emmet-language-server", "..."]
    },
    "SCSS": {
      "language_servers": ["emmet-language-server", "..."]
    },
    "JSON": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "JSONC": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "CSS": {
      "language_servers": ["emmet-language-server", "..."],
      "formatter": { "language_server": { "name": "biome" } }
    },
    "GraphQL": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true
      }
    },
    "Prisma": {
      "formatter": { "language_server": { "name": "prisma-language-server" } }
    },
    "MDX": {
      "language_servers": ["emmet-language-server", "..."]
    },
    "Nix": {
      "formatter": {
        "external": {
          "command": "alejandra"
        }
      }
    }
  },

  // ─── LSP ─────────────────────────────────────────────────────────────────
  "lsp": {
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeCompletionsForModuleExports": true,
          "includeCompletionsWithSnippetText": true,
          "includeAutomaticOptionalChainCompletions": true,
          "importModuleSpecifierPreference": "shortest",
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true
        }
      }
    },
    "biome": {
      "initialization_options": {
        "require_config_file": false
      }
    },
    "emmet-language-server": {
      "initialization_options": {
        "syntaxProfiles": {
          "javascript": "jsx",
          "javascriptreact": "jsx",
          "typescript": "jsx",
          "typescriptreact": "jsx"
        }
      }
    },
    "tailwindcss-language-server": {
      "initialization_options": {
        "userLanguages": {
          "rust": "html"
        }
      },
      "settings": {
        "tailwindCSS": {
          "experimental": {
            "classRegex": [
              ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["twMerge\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["tv\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
            ]
          }
        }
      }
    }
  },

  // ─── Terminal ────────────────────────────────────────────────────────────
  "terminal": {
    "font_family": "JetBrainsMonoNL Nerd Font Mono",
    "font_size": 12.0,
    "cursor_shape": "bar",
    "env": {
      "EDITOR": "zed --wait"
    },
    "toolbar": {
      "breadcrumbs": false
    }
  },

  // ─── Agent & AI ──────────────────────────────────────────────────────────
  "language_models": {
    "ollama": {
      "api_url": "https://ollama.com"
    },
    "opencode": {
      "show_zen_models": false
    }
  },
  "agent": {
    "default_model": {
      "provider": "ollama",
      "model": "deepseek-v4-pro",
      "enable_thinking": true
    },
    "enabled": true,
    "dock": "right",
    "button": true,
    "sidebar_side": "right"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "glm-acp-agent": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  }
}

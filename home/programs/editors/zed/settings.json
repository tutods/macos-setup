{
  "language_models": {
    "openai_compatible": {},
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "git_panel": {
    "sort_by_path": true,
    "tree_view": true,
  },
  "diff_view_style": "split",
  "agent": {
    "tool_permissions": {
      "tools": {
        "create_directory": {
          "default": "allow",
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cat\\s",
            },
            {
              "pattern": "^ls\\s",
            },
          ],
        },
      },
    },
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "z-ai/glm-4.7",
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3-pro-preview",
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-opus-4.5",
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-opus-4.6",
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-sonnet-4.5",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
      },
    ],
    "model_parameters": [],
  },
  "disable_ai": false,
  "show_edit_predictions": true,
  "format_on_save": "on",
  "notification_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "button": false,
  },
  "outline_panel": {
    "indent_size": 25,
  },
  "project_panel": {
    "auto_fold_dirs": true,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "centered_layout": {
    "left_padding": 0.1,
    "right_padding": 0.1,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
      "enabled": true,
      "delay_ms": 500,
      "min_column": 80,
    },
  },
  "scrollbar": {
    "show": "auto",
  },
  "seed_search_query_from_cursor": "selection",
  "ui_font_size": 15,
  "buffer_font_size": 14.0,
  "buffer_line_height": "comfortable",
  "base_keymap": "VSCode",
  "relative_line_numbers": "disabled",
  "terminal": {
    "font_family": "JetBrainsMonoNL Nerd Font Mono",
    "font_size": 12.0,
    "cursor_shape": "bar",
    "env": {
      "EDITOR": "zed --wait",
    },
    "toolbar": { "breadcrumbs": false },
  },
  "auto_install_extensions": {
    "biome": true,
    "dart": true,
    "fleet-themes": true,
    "git-firefly": true,
    "html": true,
    "ruff": true,
    "toml": true,
  },
  "restore_on_startup": "last_session",
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.vscode",
  ],
  "remove_trailing_whitespace_on_save": true,
  "always_treat_brackets_as_autoclosed": true,
  "auto_update": true,
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "minimap": {
    "show": "never",
  },
  "current_line_highlight": "gutter",
  "file_types": {
    "dotenv": [".env.*"],
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets", ".prettierrc"],
    "Markdown": [".rules"],
  },
  "linked_edits": true,
  "wrap_guides": [80, 120],
  "preferred_line_length": 80,
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "use_system_window_tabs": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_family": "JetBrains Mono",
  "ui_font_family": ".SystemUIFont",
  "icon_theme": "Warm Charmed Icons",
  "theme": {
    "mode": "dark",
    "light": "GitHub Light",
    "dark": "Rosé Pine Moon",
  },
  "languages": {
    "Markdown": {
      "soft_wrap": "editor_width",
      "remove_trailing_whitespace_on_save": false,
    },
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_type_hints": false,
      },
    },
    "TypeScript": {
      "language_servers": ["typescript-language-server", "biome"],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_type_hints": false,
      },
    },
    "TSX": {
      "language_servers": [
        "biome",
        "typescript-language-server",
        "tailwindcss-language-server",
      ],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
        "source.removeUnusedImports": true,
      },
      "jsx_tag_auto_close": {
        "enabled": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_type_hints": false,
      },
    },
    "JSX": {
      "language_servers": [
        "biome",
        "typescript-language-server",
        "tailwindcss-language-server",
      ],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
      "jsx_tag_auto_close": {
        "enabled": true,
      },
    },
    "JSON": { "formatter": { "language_server": { "name": "biome" } } },
    "JSONC": { "formatter": { "language_server": { "name": "biome" } } },
    "CSS": {
      "language_servers": ["tailwindcss-language-server"],
      "formatter": { "language_server": { "name": "biome" } },
    },
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx", "tw", "tv", "twMerge", "cn"],
        "experimental": {
          "classRegex": ["[cls|class|className]\\s\\:\\=\\s\"([^\"]*)"],
        },
      },
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includePackageJsonAutoImports": "auto",
          "importModuleSpecifier": "shortest",
          "importModuleSpecifierEnding": "auto",
          "useAliasesForRenames": true,
          "allowRenameOfImportPath": true,
          "allowTextChangesInNewFiles": true,
        },
        "suggest": {
          "autoImports": true,
          "paths": true,
          "includeAutomaticOptionalChainCompletions": true,
        },
        "inlayHints": {
          "parameterNames": {
            "enabled": "all",
          },
          "parameterTypes": {
            "enabled": true,
          },
          "propertyDeclarationTypes": {
            "enabled": true,
          },
          "variableTypes": {
            "enabled": true,
          },
          "functionLikeReturnTypes": {
            "enabled": true,
          },
          "enumMemberValues": {
            "enabled": true,
          },
        },
        "tsserver": {
          "maxTsServerMemory": 4096,
          "useSyntaxServer": "auto",
          "watchOptions": {
            "watchFile": "useFsEvents",
            "watchDirectory": "useFsEvents",
            "fallbackPolling": "dynamicPriority",
            "synchronousWatchDirectory": true,
            "excludeDirectories": [
              "**/node_modules",
              "**/.*",
              "**/dist",
              "**/build",
            ],
          },
        },
        "autoClosingTags": true,
        "disableAutomaticTypeAcquisition": false,
        "workspaceSymbols": {
          "scope": "allOpenProjects",
        },
      },
      "settings": {
        "codeActionsOnSave": {
          "source.organizeImports": true,
          "source.sortImports": true,
          "source.removeUnusedImports": true,
          "source.fixAll.biome": true,
        },
      },
    },
  },
  "inline_code_actions": true,
  "show_completions_on_input": true,
  "edit_predictions": {
    "provider": "none",
    "mode": "subtle",
  },
  "context_servers": {
    "code-review-graph": {
      "command": "uvx",
      "args": ["code-review-graph", "serve"],
    },
  },
}
